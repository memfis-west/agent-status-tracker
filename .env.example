TRACKER_HOST=0.0.0.0
TRACKER_PORT=8090
TRACKER_DB_PATH=/data/status.db

DEERFLOW_BASE_URL=http://127.0.0.1:2026
DEERFLOW_DATA_BASE=/home/memfis/apps/deer-flow/backend/.deer-flow
# Optional override; default = JWT sub from DEERFLOW_AUTH_COOKIE access_token
DEERFLOW_USER_ID=
# Optional: manual override (else use http://127.0.0.1:8090/settings/auth)
# Use double quotes — cookie contains semicolons
DEERFLOW_AUTH_COOKIE=""
DEERFLOW_BEARER_TOKEN=
# Optional: auto-login on tracker start (saved to data/deerflow_session.json)
DEERFLOW_LOGIN_EMAIL=
DEERFLOW_LOGIN_PASSWORD=

STALE_AFTER_SECONDS=600
STALE_CHECK_INTERVAL_SECONDS=60
DEERFLOW_THREAD_SEARCH_LIMIT=50

TRACKER_STREAM_MODES=updates,custom,messages-tuple

STORE_PAYLOADS=false
MAX_TEXT_FIELD_CHARS=500
MAX_PAYLOAD_CHARS=4000

NTFY_SERVER=
NTFY_TOPIC=

BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
